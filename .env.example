# NPC Actor System — Environment Configuration
# Copy this file to .env and fill in your values.

# ── Google Services (Required) ──────────────────────
# Get a free Gemini API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=

# ── App Configuration ───────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# ── Feature Modes ──────────────────────────────────
# Database: "memory" (in-memory, demo) or "firestore" (Google Cloud)
DATABASE_MODE=memory

# TTS: "browser" (Web Speech API) or "google" (Google Cloud TTS)
TTS_MODE=browser

# ── Security ────────────────────────────────────────
# API key for admin endpoints (required in production)
ADMIN_API_KEY=

# Comma-separated allowed CORS origins (for production)
ALLOWED_ORIGINS=

# Rate limiting
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=20
