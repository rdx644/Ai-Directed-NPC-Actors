# Google Gemini API Key (required)
GEMINI_API_KEY=your-gemini-api-key-here

# Google Cloud Project (for TTS & Firestore)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Optional: Path to service account JSON (for local development)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# App Configuration
APP_ENV=development
APP_PORT=8080
APP_HOST=0.0.0.0

# Database mode: "firestore" or "memory"
DATABASE_MODE=memory

# TTS mode: "google" or "browser" (browser uses Web Speech API)
TTS_MODE=browser
